<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only additions. The in-app self-updater (download + install APK) is a
  testing convenience and is NOT allowed by Google Play, so the permission it
  needs lives here and is merged into debug builds only — never release/Play.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
</manifest>

# Copy to .env and edit. NEVER commit the real .env (it's gitignored).
#
# SERVER_ACCESS_PASSPHRASE: if set, registration requires this exact value as the
# invite code — keep it to stop random public signups. Generate a strong one, e.g.
#   openssl rand -base64 24
# Leave blank to allow open registration.
SERVER_ACCESS_PASSPHRASE=replace-with-a-long-random-string

# Optional overrides (sensible defaults already baked into the image):
# PORT=3000
# MAX_BACKUPS_RETAINED=15

# --- OPTIONAL: recovery code delivery ---
# Account recovery works WITHOUT any of this (the user's saved recovery key is
# enough). Configure these only to add an email/SMS second factor to recovery.
#
# Email (any SMTP provider — e.g. a free Brevo/SendGrid/Mailgun tier or a Gmail
# app password). Leave blank to disable email codes.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=SentryKey <noreply@sentrykey.app>
#
# SMS via Twilio (uses the REST API; no SDK needed). Leave blank to disable SMS.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15551234567
